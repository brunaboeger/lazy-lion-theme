		},
		{
			"scope": [
				"comment",
			],
			"settings": {
				"foreground": "#576192"
			}
		},
		{
			"scope": [
				"string",
				"string.regexp",
			],
			"settings": {
				"foreground": "#6ce48a",
			}
		},
		{
			"scope": [
				"entity.other.attribute-name.html",
				"entity.other.attribute-name.html.vue",
				"meta.at-rule.keyframes.scss",
				"support.variable.property.js",
				"variable.language.this",
				"variable.object.property",
				"variable.other.property",
			],
			"settings": {
				"foreground": "#f8ab6c"
			}
		},
		{
			"scope": [
				"keyword.control",

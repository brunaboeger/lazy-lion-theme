	"tokenColors": [

		{
			"name": "TESTANDO PROPRIEDADES",
			"scope": [
				
			],
			"settings": {
				"foreground": "#ff0000",
				"fontStyle": "underline"
			}
		},
		{
			"scope": [
				"comment",
				"meta.definition.function",
